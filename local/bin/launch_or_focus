#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 3 ]] || [[ "$2" != "--" ]]; then
  echo "Usage: launch_or_focus <selector> -- <command...>" >&2
  exit 2
fi

SELECTOR="$1"
shift 2
LAUNCH_CMD=("$@")

try_focus() {
  local output
  output=$(hyprctl eval '
    local w = hl.get_window("'"$1"'")
    if w then
      hl.dispatch(hl.dsp.focus({ window = w }))
      return "ok"
    end
    return "not found"
  ' 2>&1)
  [[ "$output" == *"ok"* ]]
}

if try_focus "class:${SELECTOR}" || try_focus "title:${SELECTOR}"; then
  exit 0
fi

exec "${LAUNCH_CMD[@]}" >/dev/null 2>&1
