#!/bin/bash
HYPR_DIR="$HOME/.config/hypr"
ACTIVE="$HYPR_DIR/active_monitor.conf"
CONFIG_DIR="$HYPR_DIR/monitor_configs" # folder to scan — adjust if needed

current=$(readlink "$ACTIVE" 2>/dev/null | xargs basename 2>/dev/null)

# Collect configs into parallel arrays
names=()
files=()

while IFS= read -r -d '' file; do
  filename=$(basename "$file")
  name=$(basename "$file" .conf | tr '_' ' ' | sed 's/\b\(.\)/\u\1/g')
  files+=("$filename")
  if [[ "$filename" == "$current" ]]; then
    names+=("* $name")
  else
    names+=("$name")
  fi
done < <(find "$CONFIG_DIR" -maxdepth 1 -name "*.conf" -print0 | sort -z)

if [[ ${#files[@]} -eq 0 ]]; then
  notify-send "Monitor Select" "No configs found in $CONFIG_DIR"
  exit 1
fi

# Build the menu string and show it
menu=$(printf '%s\n' "${names[@]}")
chosen=$(echo "$menu" | rofi -dmenu -i -p "Monitor Config")
[[ -z "$chosen" ]] && exit 0

# Strip the active marker and find the matching filename
chosen_clean="${chosen#\* }"
target=""
for i in "${!names[@]}"; do
  clean="${names[$i]#\* }"
  if [[ "$clean" == "$chosen_clean" ]]; then
    target="${files[$i]}"
    break
  fi
done

if [[ -z "$target" ]]; then
  notify-send "Monitor Select" "Unknown config: $chosen_clean"
  exit 1
fi

ln -sf "$CONFIG_DIR/$target" "$ACTIVE"
hyprctl reload
notify-send "Monitor Select" "Switched to: $chosen_clean"
